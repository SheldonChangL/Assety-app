<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive icon foreground — 108×108dp viewport.
    Safe zone: 18–90dp (72×72dp centred at 54,54).
    Visual content intentionally kept within ~20–88dp with breathing room.

    Elements (drawn front-to-back):

    1. House silhouette — white, fillType="evenOdd"
       Roof peak : (54, 22)
       Eaves     : (20, 50) and (88, 50)  [8dp overhang on each side]
       Walls     : x 28–80, y 50–84
       Cut-outs  : left window (33,54)–(44,66)
                   right window (64,54)–(75,66)
                   arched door (47,84)–arch-top(54,60)–(61,84)

    2. Security shield — medium teal (#80CBC4), centred in door arch
    3. Check-mark — white stroke, inside shield
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── House with even-odd cut-outs ─────────────────────────────────── -->
    <path
        android:fillColor="#FFFFFF"
        android:fillType="evenOdd"
        android:pathData="
            M 54,22 L 88,50 L 80,50 L 80,84 L 28,84 L 28,50 L 20,50 Z
            M 33,54 L 44,54 L 44,66 L 33,66 Z
            M 64,54 L 75,54 L 75,66 L 64,66 Z
            M 47,84 L 47,67 A 7,7 0 0 0 61,67 L 61,84 Z
        " />

    <!-- ── Security shield badge (sits in the door arch) ────────────────── -->
    <!--
        Shield: rounded top shoulders, pointed bottom.
        x: 48.5–59.5  y: 68.5–83.5  (fully inside the door cut-out)
    -->
    <path
        android:fillColor="#80CBC4"
        android:pathData="
            M 54,68.5
            L 59.5,71.5
            L 59.5,77.0
            Q 59.5,83.5 54,84.5
            Q 48.5,83.5 48.5,77.0
            L 48.5,71.5
            Z
        " />

    <!-- ── Check-mark inside shield ─────────────────────────────────────── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M 51.0,76.5 L 53.5,79.0 L 58.0,74.0" />

</vector>
