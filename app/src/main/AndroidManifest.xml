<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        INTERNET permission is intentionally omitted.
        This is a 100% offline, air-gapped application.
    -->

    <!-- CameraX: physical camera access -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- WorkManager: local warranty/maintenance notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Declare camera as optional so the app is available on non-camera devices -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.camera.autofocus"
        android:required="false" />

    <!--
        SAF queries: declare intent actions the app resolves at runtime.
        Required for package visibility on Android 11+ (API 30+).
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.CREATE_DOCUMENT" />
        </intent>
        <intent>
            <action android:name="android.intent.action.OPEN_DOCUMENT" />
        </intent>
    </queries>

    <application
        android:name=".HomeAssetKeeperApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HomeAssetKeeper">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.HomeAssetKeeper">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            WorkManager foreground service declaration.
            Required when WorkManager falls back to a ForegroundService for expedited jobs.
            tools:node="merge" allows WorkManager's own manifest entry to merge in.
        -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />

        <!--
            Disable WorkManager's default App Startup initializer.
            When using hilt-work, WorkManager must be initialised manually via
            Configuration.Provider in HomeAssetKeeperApplication so that Hilt's
            HiltWorkerFactory is used. Without this removal, WorkManager
            self-initialises (without HiltWorkerFactory) AND registers its
            constraint-tracking receivers independently, which can cause
            RECEIVER_NOT_EXPORTED SecurityExceptions on Android 13+.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
